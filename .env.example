# AP Vision Care Portal — Environment Variables
# Copy to .env.local for local development

# --- Auth (Keycloak via next-auth v5) ---
# Leave KEYCLOAK_ISSUER empty to use demo role-picker login
KEYCLOAK_ISSUER=http://localhost:8080/realms/ap-vision-care
KEYCLOAK_CLIENT_ID=apvc-web
KEYCLOAK_CLIENT_SECRET=your-client-secret

# next-auth secret (generate: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:3100

# Set to "true" to force demo login even when Keycloak is configured
AUTH_DEMO_MODE=false

# Client-side auth mode: "demo" | "keycloak"
NEXT_PUBLIC_AUTH_MODE=demo

# --- API Gateway (BFF proxies to this) ---
API_GATEWAY_URL=http://localhost:3000
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:3000/api/v1

# --- ABHA / ABDM (proxied via /api/abha) ---
ABHA_API_URL=https://healthidsbx.abdm.gov.in/api/v1
ABHA_CLIENT_ID=
ABHA_CLIENT_SECRET=
